{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "@cloudflare/workers-types",
      "node"
    ],
    "baseUrl": "."
  },
  "include": [
    "worker/**/*.ts",
    "tests/**/*.ts"
  ]
}
